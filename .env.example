# G.Creators MVP - Environment Variables Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to git (it's in .gitignore)

# =============================================================================
# SUPABASE CONFIGURATION
# =============================================================================
# Where to get: https://supabase.com/dashboard/project/_/settings/api
# 1. Go to your Supabase project dashboard
# 2. Click on "Settings" → "API"
# 3. Copy the values below

# IMPORTANT: This project uses Vite, so use VITE_ prefix (not NEXT_PUBLIC_)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key

# For compatibility with some tools, keep these too:
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Note: 
# - PUBLISHABLE_KEY/ANON_KEY is safe to expose in frontend (public)
# - SERVICE_ROLE_KEY must be kept secret (server-side only)

# =============================================================================
# STRIPE CONFIGURATION
# =============================================================================
# Where to get: https://dashboard.stripe.com/apikeys
# 1. Create/login to Stripe account
# 2. Go to Developers → API keys
# 3. Toggle "Viewing test data" to get test keys (switch to live for production)

# Publishable key (safe for frontend)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_51...

# Secret key (server-side only, keep secret!)
STRIPE_SECRET_KEY=sk_test_51...

# Webhook secret (for verifying webhook signatures)
# Where to get: https://dashboard.stripe.com/webhooks
# 1. Create endpoint: https://yourdomain.com/api/webhooks/stripe
# 2. Copy the webhook signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Connect settings
# Platform fee (percentage as decimal, e.g., 0.15 = 15%)
STRIPE_PLATFORM_FEE=0.15

# =============================================================================
# AI / MACHINE LEARNING CONFIGURATION
# =============================================================================
# Choose ONE of these AI providers (recommended: start with Gemini, upgrade to OpenAI later)

# --- OPTION 1: OpenAI (Best quality, higher cost) ---
# Where to get: https://platform.openai.com/api-keys
# 1. Create/login to OpenAI account
# 2. Go to API keys section
# 3. Create new secret key
# Cost: GPT-4o: $2.50/$10 per 1M tokens, Whisper: $0.006/min
# For mentor recommendations: also add this as a Supabase secret (Dashboard → Settings → Edge Functions → Secrets).
OPENAI_API_KEY=sk-proj-...

# Optional: JWT for server/cron calls to recommend-mentors. Set in Supabase Edge Function secrets as RECOMMEND_MENTORS_SERVICE_JWT.
# If the request sends Authorization: Bearer <this-jwt> and body.userId, the function uses service role for that user.
# RECOMMEND_MENTORS_SERVICE_JWT=<your-secret-jwt>

# --- OPTION 2: Google Gemini (Budget-friendly) ---
# Where to get: https://aistudio.google.com/app/apikey
# 1. Create/login to Google AI Studio
# 2. Get API key
# Cost: Gemini Flash: $0.075/$0.30 per 1M tokens (much cheaper!)
GOOGLE_GEMINI_API_KEY=AIzaSy...

# --- OPTION 3: Anthropic Claude (Balanced) ---
# Where to get: https://console.anthropic.com/settings/keys
# 1. Create/login to Anthropic account
# 2. Generate API key
# Cost: Claude 3.5: $3/$15 per 1M tokens
ANTHROPIC_API_KEY=sk-ant-...

# AI Model Selection (uncomment ONE)
AI_PROVIDER=gemini
# AI_PROVIDER=openai
# AI_PROVIDER=anthropic

# Model names
AI_MODEL_NAME=gemini-1.5-flash
# AI_MODEL_NAME=gpt-4o-mini
# AI_MODEL_NAME=claude-3-5-sonnet-20241022

# AI Conversation Limits
AI_MAX_MESSAGES_PER_DAY=50
AI_MAX_TOKENS_PER_CONVERSATION=4000

# =============================================================================
# TRANSLATION SERVICE
# =============================================================================
# Choose ONE of these translation providers

# --- OPTION 1: DeepL (Recommended - best quality for EU languages) ---
# Where to get: https://www.deepl.com/pro-api
# 1. Sign up for DeepL API account
# 2. Get your API key
# Cost: FREE for 500k chars/month, then $5.49 per 1M chars
DEEPL_API_KEY=your-deepl-api-key-here:fx

# --- OPTION 2: Google Cloud Translation ---
# Where to get: https://console.cloud.google.com/apis/credentials
# 1. Create GCP project
# 2. Enable Cloud Translation API
# 3. Create API key
# Cost: $20 per 1M characters
GOOGLE_TRANSLATE_API_KEY=AIzaSy...

# Translation Service Selection
TRANSLATION_PROVIDER=deepl
# TRANSLATION_PROVIDER=google

# Supported languages (comma-separated ISO codes)
TRANSLATION_LANGUAGES=en,uk,ru,es,fr,de,pl,pt

# =============================================================================
# GOOGLE CLOUD SERVICES (Calendar, Speech-to-Text, Text-to-Speech)
# =============================================================================
# Where to get: https://console.cloud.google.com/apis/credentials
# 1. Create GCP project (or use existing)
# 2. Enable required APIs: Calendar API, Cloud Speech-to-Text, Cloud TTS
# 3. Create OAuth 2.0 Client ID

# OAuth 2.0 Client (for Google Calendar integration)
GOOGLE_CLIENT_ID=123456789012-abcdefghijklmnopqrstuvwxyz123456.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-abcdefghijklmnopqrstuvwxyz
GOOGLE_REDIRECT_URI=https://yourdomain.com/api/auth/google/callback

# Optional: Service Account for server-side operations
# (Create at: https://console.cloud.google.com/iam-admin/serviceaccounts)
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service@project-id.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}

# =============================================================================
# MICROSOFT GRAPH API (Outlook Calendar Integration)
# =============================================================================
# Where to get: https://portal.azure.com/#view/Microsoft_AAD_RegisteredApps
# 1. Register app in Azure AD
# 2. Add Microsoft Graph permissions: Calendars.ReadWrite
# 3. Get credentials

MICROSOFT_CLIENT_ID=12345678-1234-1234-1234-123456789012
MICROSOFT_CLIENT_SECRET=abc~123456789012345678901234567890
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=https://yourdomain.com/api/auth/microsoft/callback

# =============================================================================
# TEXT-TO-SPEECH SERVICE (Optional - for AI Avatar voice)
# =============================================================================
# Choose ONE if you want voice responses

# --- OPTION 1: ElevenLabs (Best quality, voice cloning) ---
# Where to get: https://elevenlabs.io/app/settings/api-keys
# 1. Create ElevenLabs account
# 2. Get API key
# Cost: $99/month for 100k characters
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# --- OPTION 2: Google Cloud Text-to-Speech ---
# Uses same GCP project as above
# Cost: $16 per 1M characters
# (No additional key needed if GOOGLE_SERVICE_ACCOUNT_KEY is set)

# TTS Provider Selection
TTS_PROVIDER=elevenlabs
# TTS_PROVIDER=google

# Voice settings
TTS_DEFAULT_VOICE_ID=21m00Tcm4TlvDq8ikWAM
TTS_DEFAULT_LANGUAGE=en-US

# =============================================================================
# EMAIL SERVICE (Transactional Emails)
# =============================================================================
# Choose ONE email provider

# --- OPTION 1: Resend (Recommended - modern, easy) ---
# Where to get: https://resend.com/api-keys
# 1. Create Resend account
# 2. Verify your domain
# 3. Generate API key
# Cost: FREE for 3k emails/month, then $20/month for 50k
RESEND_API_KEY=re_123456789abcdefghijklmnopqrstuvwxyz

# --- OPTION 2: SendGrid ---
# Where to get: https://app.sendgrid.com/settings/api_keys
# 1. Create SendGrid account
# 2. Generate API key
# Cost: FREE for 100 emails/day, then $19.95/month for 50k
SENDGRID_API_KEY=SG.abcdefghijklmnopqrstuvwxyz123456789012345678901234567890

# Email Provider Selection
EMAIL_PROVIDER=resend
# EMAIL_PROVIDER=sendgrid

# Email settings
EMAIL_FROM=noreply@gcreators.me
EMAIL_FROM_NAME=G.Creators

# =============================================================================
# SMS NOTIFICATIONS (Optional - for booking reminders)
# =============================================================================
# Where to get: https://console.twilio.com/
# 1. Create Twilio account
# 2. Get Account SID and Auth Token
# 3. Get a phone number
# Cost: Pay-as-you-go, ~$0.01-0.02 per SMS

TWILIO_ACCOUNT_SID=AC1234567890abcdefghijklmnopqrstuvw
TWILIO_AUTH_TOKEN=your-auth-token-here
TWILIO_PHONE_NUMBER=+1234567890

# Enable/disable SMS
SMS_ENABLED=false

# =============================================================================
# VIDEO STORAGE & CDN
# =============================================================================
# Choose ONE option

# --- OPTION 1: Supabase Storage (Included in Supabase plan) ---
# No additional configuration needed if using Supabase

# --- OPTION 2: Cloudflare R2 (Better for large video files) ---
# Where to get: https://dash.cloudflare.com/
# 1. Create R2 bucket
# 2. Create API token
# Cost: $0.015/GB storage, no egress fees
CLOUDFLARE_ACCOUNT_ID=your-account-id
CLOUDFLARE_R2_ACCESS_KEY_ID=your-access-key
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your-secret-key
CLOUDFLARE_R2_BUCKET_NAME=gcreators-media
CLOUDFLARE_R2_PUBLIC_URL=https://media.gcreators.me

# Storage provider selection
STORAGE_PROVIDER=supabase
# STORAGE_PROVIDER=cloudflare-r2

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

# Application URL (change for production)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# Environment
NODE_ENV=development
# NODE_ENV=production

# Site Information
NEXT_PUBLIC_SITE_NAME=G.Creators
NEXT_PUBLIC_SITE_DESCRIPTION=AI-Powered Mentorship Platform

# =============================================================================
# RATE LIMITING & SECURITY
# =============================================================================

# JWT Secret (generate with: openssl rand -base64 32)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Session Secret (generate with: openssl rand -base64 32)
SESSION_SECRET=your-session-secret-key-change-this-too

# Rate Limiting (requests per time window)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS Settings (comma-separated allowed origins)
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://gcreators.me

# =============================================================================
# DATABASE BACKUP (Optional but recommended)
# =============================================================================
# Supabase has automatic backups, but you can set up additional backup destination

# AWS S3 for backups
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_BACKUP_BUCKET=gcreators-backups
AWS_REGION=us-east-1

# Backup schedule (cron format)
BACKUP_CRON_SCHEDULE=0 2 * * *

# =============================================================================
# MONITORING & ANALYTICS (Optional but recommended)
# =============================================================================

# Sentry (Error tracking)
# Where to get: https://sentry.io/settings/projects/
NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
SENTRY_AUTH_TOKEN=your-sentry-auth-token

# Google Analytics
# Where to get: https://analytics.google.com/
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# PostHog (Product analytics)
# Where to get: https://app.posthog.com/project/settings
NEXT_PUBLIC_POSTHOG_KEY=phc_abcdefghijklmnopqrstuvwxyz123456789
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Enable/disable features
FEATURE_AI_AVATAR=true
FEATURE_VIDEO_RESPONSES=true
FEATURE_CHAT=true
FEATURE_TRANSLATIONS=true
FEATURE_FORMAT_CONVERSION=true
FEATURE_SMS_NOTIFICATIONS=false

# =============================================================================
# DEVELOPMENT TOOLS (Development only)
# =============================================================================

# Enable debug logging
DEBUG=false

# Stripe testing mode
STRIPE_TEST_MODE=true

# Seed database on startup
SEED_DATABASE=false

# Mock external APIs (for testing without API keys)
MOCK_AI_API=false
MOCK_TRANSLATION_API=false
MOCK_EMAIL_API=false

# =============================================================================
# PERFORMANCE SETTINGS
# =============================================================================

# Caching
REDIS_URL=redis://localhost:6379
CACHE_TTL=3600

# File upload limits (in MB)
MAX_FILE_SIZE_MB=500
MAX_VIDEO_SIZE_MB=2000

# API timeouts (in milliseconds)
API_TIMEOUT_MS=30000
AI_TIMEOUT_MS=60000
